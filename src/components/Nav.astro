---
import { getMenu, getSiteSettings } from "emdash";

const settings = await getSiteSettings();
const siteTitle = settings?.title || "Orlando Spine Studio";
const menu = await getMenu("primary");
---

<nav id="navbar">
  <a href="/" class="nav-logo">
    <img src="/logo/OSS_Horizontal.png" alt={siteTitle} />
  </a>
  <ul class="nav-links">
    {menu?.items.map((item) => (
      <li>
        <a href={item.url} target={item.target}>
          {item.label}
        </a>
      </li>
    ))}
    <li><a href="tel:4076586500" class="nav-phone">(407) 658-6500</a></li>
    <li><a href="/contact" class="nav-cta">Book Appointment</a></li>
  </ul>

  <button class="hamburger" aria-label="Menu">
    <span></span>
    <span></span>
    <span></span>
  </button>
</nav>

<div class="mobile-overlay"></div>
<div class="mobile-menu">
  <ul>
    {menu?.items.map((item) => (
      <li><a href={item.url}>{item.label}</a></li>
    ))}
  </ul>
  <div class="mobile-menu-cta">
    <a href="/contact">Book Appointment</a>
    <a href="tel:4076586500" class="mobile-phone">(407) 658-6500</a>
  </div>
</div>

<script>
  const navbar = document.getElementById("navbar");
  window.addEventListener("scroll", () => {
    navbar?.classList.toggle("scrolled", window.scrollY > 40);
  });

  const hamburger = document.querySelector(".hamburger");
  const mobileMenu = document.querySelector(".mobile-menu");
  const overlay = document.querySelector(".mobile-overlay");

  function toggleMenu() {
    hamburger?.classList.toggle("open");
    mobileMenu?.classList.toggle("open");
    overlay?.classList.toggle("open");
    document.body.style.overflow = mobileMenu?.classList.contains("open") ? "hidden" : "";
  }

  hamburger?.addEventListener("click", toggleMenu);
  overlay?.addEventListener("click", toggleMenu);
  mobileMenu?.querySelectorAll("a").forEach((a) => a.addEventListener("click", toggleMenu));
</script>

<style>
  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    padding: 8px max(48px, calc((100% - 1440px) / 2));
    height: 72px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: var(--nav-bg);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid transparent;
    transition: border-color 0.3s, box-shadow 0.3s;
  }

  nav:global(.scrolled) {
    border-color: var(--border);
    box-shadow: 0 2px 20px rgba(0, 0, 0, 0.05);
  }

  .nav-logo { display: flex; align-items: center; }
  .nav-logo img { height: 65px; width: auto; }

  .nav-links {
    display: flex;
    gap: 32px;
    list-style: none;
    align-items: center;
  }

  .nav-links a {
    font-size: 14px;
    font-weight: 500;
    color: var(--text-secondary);
    text-decoration: none;
    transition: color 0.2s;
  }

  .nav-links a:hover { color: var(--text); }

  .nav-cta {
    background: var(--accent) !important;
    color: #fff !important;
    font-weight: 600 !important;
    padding: 10px 22px;
    border-radius: 8px;
    font-size: 14px !important;
    transition: background 0.2s, transform 0.2s, box-shadow 0.2s !important;
  }

  .nav-cta:hover {
    background: var(--accent-dark) !important;
    transform: translateY(-1px);
    box-shadow: 0 4px 16px var(--accent-glow) !important;
  }

  .nav-phone {
    font-size: 13px !important;
    font-weight: 600 !important;
    color: var(--text) !important;
  }

  /* Hamburger */
  .hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    cursor: pointer;
    padding: 8px;
    background: none;
    border: none;
    z-index: 1001;
  }

  .hamburger span {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--text);
    border-radius: 2px;
    transition: transform 0.3s, opacity 0.3s;
  }

  .hamburger:global(.open) span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .hamburger:global(.open) span:nth-child(2) { opacity: 0; }
  .hamburger:global(.open) span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  /* Mobile menu */
  .mobile-menu {
    display: none;
    position: fixed;
    top: 0; right: 0; bottom: 0;
    width: 280px;
    background: var(--bg);
    border-left: 1px solid var(--border);
    z-index: 999;
    padding: 80px 32px 40px;
    transform: translateX(100%);
    transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
    flex-direction: column;
  }

  .mobile-menu:global(.open) { transform: translateX(0); }

  .mobile-menu ul { list-style: none; }
  .mobile-menu li { border-bottom: 1px solid var(--border); }

  .mobile-menu a {
    display: block;
    padding: 18px 0;
    font-size: 16px;
    font-weight: 500;
    color: var(--text-secondary);
    text-decoration: none;
    transition: color 0.2s;
  }

  .mobile-menu a:hover { color: var(--accent); }

  .mobile-menu-cta { margin-top: 28px; }

  .mobile-menu-cta a {
    display: block;
    background: var(--accent);
    color: #fff !important;
    font-weight: 700 !important;
    text-align: center;
    padding: 14px 24px;
    border-radius: 8px;
    font-size: 15px;
    margin-bottom: 12px;
  }

  .mobile-phone {
    display: block;
    text-align: center;
    font-weight: 600;
    color: var(--text) !important;
    background: transparent !important;
    padding: 10px !important;
  }

  :global(.mobile-overlay) {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.4);
    z-index: 998;
  }

  :global(.mobile-overlay.open) { display: block; }

  @media (max-width: 768px) {
    .nav-links { display: none; }
    .hamburger { display: flex; }
    .mobile-menu { display: flex; }
  }
</style>
