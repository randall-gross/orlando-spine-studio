---
interface Props {
  node: {
    headline: string;
    subheadline?: string;
    primaryCta?: { label: string; url: string };
    secondaryCta?: { label: string; url: string };
    videoSrc?: string;
    badge?: string;
    services?: Array<{ icon: string; title: string }>;
    stats?: Array<{ value: string; label: string }>;
  };
}

const { node } = Astro.props;
const { headline, subheadline, primaryCta, secondaryCta, videoSrc, badge, services, stats } = node;
---

<section class="hero">
  <div class="hero-left">
    {badge && <span class="hero-badge">{badge}</span>}
    <h1 class="hero-headline">{headline}</h1>
    {subheadline && <p class="hero-subheadline">{subheadline}</p>}
    {(primaryCta || secondaryCta) && (
      <div class="hero-actions">
        {primaryCta && <a href={primaryCta.url} class="btn btn-primary">{primaryCta.label}</a>}
        {secondaryCta && <a href={secondaryCta.url} class="btn btn-secondary">{secondaryCta.label}</a>}
      </div>
    )}
    {stats && stats.length > 0 && (
      <div class="hero-stats">
        {stats.map((stat) => (
          <div class="hero-stat">
            <span class="hero-stat-value">{stat.value}</span>
            <span class="hero-stat-label">{stat.label}</span>
          </div>
        ))}
      </div>
    )}
  </div>
  <div class="hero-right">
    {videoSrc && (
      <video autoplay muted loop playsinline class="hero-video">
        <source src={videoSrc} type="video/mp4" />
      </video>
    )}
    <div class="hero-right-overlay"></div>
    {services && services.length > 0 && (
      <div class="hero-card glass">
        <div class="hero-card-title">Our Services</div>
        {services.map((svc) => (
          <div class="hero-card-item">
            <span class="hero-card-icon">{svc.icon}</span>
            <span>{svc.title}</span>
          </div>
        ))}
      </div>
    )}
  </div>
</section>

<style>
  .hero {
    padding-top: 72px;
    min-height: 100vh;
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    background: var(--bg);
    overflow: hidden;
  }

  .hero-left {
    padding: 80px 60px 80px max(88px, calc((100vw - 1400px) / 2));
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 16px;
    background: var(--accent-soft);
    color: var(--accent);
    font-size: 13px;
    font-weight: 600;
    border-radius: 100px;
    width: fit-content;
    letter-spacing: 0.5px;
  }

  .hero-headline { animation: fadeUp 0.6s ease both; }
  .hero-subheadline { color: var(--text-secondary); max-width: 520px; animation: fadeUp 0.6s ease 0.15s both; }
  .hero-actions { display: flex; gap: 16px; flex-wrap: wrap; animation: fadeUp 0.6s ease 0.3s both; }

  .hero-stats { display: flex; gap: 32px; margin-top: 16px; animation: fadeUp 0.6s ease 0.45s both; }
  .hero-stat { display: flex; flex-direction: column; }
  .hero-stat-value { font-family: var(--font-display), system-ui, sans-serif; font-size: 28px; font-weight: 700; color: var(--accent); }
  .hero-stat-label { font-size: 13px; color: var(--text-muted); }

  .hero-right {
    position: relative;
    height: 100%;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .hero-video { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }

  .hero-right-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to right, var(--bg) 0%, transparent 30%),
                linear-gradient(to top, rgba(0,0,0,0.4) 0%, transparent 50%);
    z-index: 1;
  }

  .hero-card {
    position: relative; z-index: 2;
    padding: 28px; width: 280px;
    display: flex; flex-direction: column; gap: 16px;
  }

  .hero-card-title { font-size: 13px; font-weight: 600; text-transform: uppercase; letter-spacing: 1.5px; color: rgba(255,255,255,0.5); }
  .hero-card-item { display: flex; align-items: center; gap: 12px; font-size: 15px; color: rgba(255,255,255,0.85); font-weight: 500; }
  .hero-card-icon { font-size: 18px; }

  @media (max-width: 768px) {
    .hero { grid-template-columns: 1fr; min-height: auto; }
    .hero-left { padding: 120px 24px 48px; order: 2; }
    .hero-right { min-height: 50vh; order: 1; }
    .hero-stats { gap: 24px; }
    .hero-card { display: none; }
  }
</style>
