---
interface Props {
  node: {
    headline?: string;
    items: Array<{
      metric: string;
      label: string;
      description: string;
    }>;
  };
}

const { node } = Astro.props;
const { headline, items } = node;
---

<section class="why-us section">
  {headline && <h2 class="why-us-headline">{headline}</h2>}
  <div class="why-us-grid">
    {items.map((item) => (
      <div class="why-us-card">
        <span class="why-us-metric">{item.metric}</span>
        <span class="why-us-label">{item.label}</span>
        <p class="why-us-desc">{item.description}</p>
      </div>
    ))}
  </div>
</section>

<style>
  .why-us { text-align: center; }
  .why-us-headline { margin-bottom: 56px; }

  .why-us-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
  }

  .why-us-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    padding: 40px 24px;
  }

  .why-us-metric {
    font-family: var(--font-display), system-ui, sans-serif;
    font-size: clamp(48px, 6vw, 72px);
    font-weight: 800;
    color: var(--accent);
    line-height: 1;
    letter-spacing: -0.03em;
  }

  .why-us-label {
    font-size: 13px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--text-muted);
    margin-top: 4px;
  }

  .why-us-desc {
    font-size: 15px;
    color: var(--text-secondary);
    line-height: 1.6;
    max-width: 320px;
    margin-top: 12px;
  }

  @media (max-width: 768px) {
    .why-us-grid { grid-template-columns: 1fr; gap: 16px; }
    .why-us-card { padding: 24px; }
  }
</style>
