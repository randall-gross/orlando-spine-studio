---
interface Props {
  node: {
    headline: string;
    subtext?: string;
    ctaLabel: string;
    ctaUrl: string;
    insuranceLogos?: string[];
  };
}

const { node } = Astro.props;
const { headline, subtext, ctaLabel, ctaUrl, insuranceLogos } = node;
---

<section class="cta-dark">
  <h2 class="cta-headline">{headline}</h2>
  {subtext && <p class="cta-subtext">{subtext}</p>}
  <a href={ctaUrl} class="btn btn-primary btn-lg cta-btn">{ctaLabel}</a>
  {insuranceLogos && insuranceLogos.length > 0 && (
    <div class="cta-insurance">
      <span class="cta-insurance-label">We accept most major insurance</span>
      <div class="cta-insurance-logos">
        {insuranceLogos.map((logo) => (
          <span class="cta-insurance-logo">{logo}</span>
        ))}
      </div>
    </div>
  )}
</section>

<style>
  .cta-dark {
    background: var(--dark-footer);
    padding: clamp(64px, 10vw, 120px) max(48px, calc((100% - 1440px) / 2));
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
  }

  .cta-headline {
    color: #f1f5f9;
    max-width: 700px;
  }

  .cta-subtext {
    color: rgba(255, 255, 255, 0.5);
    max-width: 560px;
    font-size: 16px;
  }

  .cta-btn { margin-top: 8px; }

  .cta-insurance { margin-top: 32px; }

  .cta-insurance-label {
    font-size: 12px;
    color: rgba(255, 255, 255, 0.3);
    text-transform: uppercase;
    letter-spacing: 1.5px;
    font-weight: 600;
  }

  .cta-insurance-logos {
    display: flex;
    gap: 24px;
    justify-content: center;
    flex-wrap: wrap;
    margin-top: 16px;
  }

  .cta-insurance-logo {
    font-size: 14px;
    color: rgba(255, 255, 255, 0.25);
    font-weight: 600;
  }
</style>
